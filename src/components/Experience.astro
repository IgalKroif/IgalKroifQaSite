---
import TestRunner from './TestRunner.astro';
---

<div class="space-y-8 font-mono">
  <div>
    <h2 class="text-xl font-bold tracking-widest text-[var(--color-accent)] uppercase mb-1">
      📂 NERV TACTICAL OPERATION LOGS
    </h2>
    <p class="text-xs text-white/50">ACCESS LEVEL: SYSTEM ADMINISTRATOR REQUIRED</p>
  </div>

  <!-- DEPLOYMENT RECORD 1 -->
  <div class="border-l-2 border-[var(--color-accent)] pl-4 ml-2 space-y-3 relative">
    <div class="absolute w-3 h-3 bg-[var(--color-bg)] border-2 border-[var(--color-accent)] rounded-full -left-[7px] top-1"></div>
    
    <div class="flex flex-col md:flex-row md:justify-between md:items-baseline border-b border-white/5 pb-1">
      <div>
        <h3 class="text-md font-bold text-[var(--color-highlight)] uppercase tracking-wide">
          OPERATION: CORE FINANCIAL FRAMEWORK STABILIZATION
        </h3>
        <span class="text-sm text-white font-bold">Tesnet Group Ltd • Full-time</span>
      </div>
      <div class="text-xs text-[var(--color-subtext)] font-semibold mt-1 md:mt-0">
        MAY 2023 — PRESENT › TEL AVIV (HYBRID)
      </div>
    </div>

    <ul class="space-y-2 text-sm text-white/80">
      <li>Architected and scaled robust, end-to-end API test automation frameworks from scratch using Java and RestAssured.</li>
      <li>Configured comprehensive automation suites driven by JUnit and TestNG to safeguard core banking backend stability.</li>
      <li>Engineered custom browser extensions and tailored workflow optimization software, significantly increasing cross-team operational speeds and testing efficiency for QA engineers.</li>
      <li>Pioneered cutting-edge testing methodologies by implementing Kiro usage integrated with AI engines to streamline test generation and script maintenance.</li>
    </ul>
  </div>

  <!-- DEPLOYMENT RECORD 2 -->
  <div class="border-l-2 border-white/20 pl-4 ml-2 space-y-3 relative">
    <div class="absolute w-3 h-3 bg-[var(--color-bg)] border-2 border-white/20 rounded-full -left-[7px] top-1"></div>
    
    <div class="flex flex-col md:flex-row md:justify-between md:items-baseline border-b border-white/5 pb-1">
      <div>
        <h3 class="text-md font-bold text-white/50 uppercase tracking-wide">
          OPERATION: INTEGRATED BANKING DATASET VALIDATION
        </h3>
        <span class="text-sm text-white/70 font-bold">Qualitest • Full-time</span>
      </div>
      <div class="text-xs text-[var(--color-subtext)] opacity-60 mt-1 md:mt-0">
        FEB 2022 — MAY 2023 › TEL AVIV DISTRICT
      </div>
    </div>

    <ul class="space-y-2 text-sm text-white/60">
      <li>Served as a core Manual Engineering Specialist, authoring high-coverage functional, integration, and regression test specifications for enterprise banking layers.</li>
      <li>Leveraged deep exploratory testing principles alongside Teradata SQL data mapping models to validate sophisticated system integrations and database states.</li>
      <li>Deconstructed complex software requirements into concrete structural designs, uncovering critical software defects ahead of aggressive deployment dates.</li>
    </ul>
  </div>

  <!-- 🧪 INTERACTIVE AUTOMATION TESTING SIMULATOR INTEGRATION -->
  <div class="pt-4">
    <TestRunner />
  </div>
</div>