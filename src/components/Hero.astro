---
import Terminal from './ui/Terminal.astro';
import Button from './ui/Button.astro';
---
<section class="flex flex-col items-center justify-center py-20 text-center">
  <h1 class="text-5xl font-bold mb-4">Igal Kroif</h1>
  <p class="text-xl mb-8">QA Engineer | Automation Specialist</p>
  <Terminal lines={[
    "Initializing terminal...",
    "Loading stack...",
    "Java | Python | JavaScript | Selenium | SQL | Postman | Jenkins",
    "Ready."
