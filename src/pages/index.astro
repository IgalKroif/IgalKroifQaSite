import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
---

<Layout title="Igal Kroif | QA Engineer">
  <!-- 🛡️ THIS CONTAINER FORCES PERFECT VERTICAL ALIGNMENT FOR ALL SECTIONS -->
  <main class="max-w-4xl mx-auto px-6 py-12 space-y-16 clear-both">
    <Hero />
    <About />
    <Experience />
    <Skills />
  </main>
</Layout>