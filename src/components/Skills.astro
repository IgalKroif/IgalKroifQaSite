---
const skillCategories = [
  {
    title: "Coding Languages & Frameworks",
    items: [
      { label: "Languages", value: "Core Java, Python, Python OOP, JavaScript, HTML, CSS" },
      { label: "Automation", value: "Selenium WebDriver, Rest Assured API Automation" },
      { label: "Testing Modules", value: "Jest, Mocha, Pytest, E2E & Compatibility Testing" }
    ]
  },
  {
    title: "Tools & Environments",
    items: [
      { label: "API & Data", value: "Postman (API), SoapUI, JSON, BSON, XML" },
      { label: "Databases", value: "PostgreSQL, MS SQL Server, MySQL Workbench, Teradata, MongoDB" },
      { label: "CI/CD & Tracking", value: "Jenkins, GitHub Actions, Jira (X-Ray), Bugzilla, QC/HP ALM" },
      { label: "Reporting", value: "Extent Reports, Allure Reports" }
    ]
  }
];
---
<section class="my-8">
  <h2>Technical Stack & Skillsets</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
    {skillCategories.map((category) => (
      <div class="p-4 rounded bg-eva-card border border-eva1-purple/30">
        <h3 class="text-md font-bold text-eva1-green mb-2">{category.title}</h3>
        <ul class="list-none space-y-1 text-sm">
          {category.items.map((skill) => (
            <li>🔹 <b>{skill.label}:</b> {skill.value}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>