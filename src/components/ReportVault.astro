---
/* 📊 NERV AUTOMATED SYSTEM EXECUTION REPORT ARCHIVE MODULE */
const historicalTestSuites = [
  {
    suiteName: "Core Banking Transaction Gateway Pipeline Architecture",
    type: "RestAssured API Automation Engine Suite",
    executionDate: "JUNE 2026",
    totalAssertions: 412,
    passed: 412,
    failed: 0,
    logVerdict: "PATTERN BLUE MINIMIZED & SAFELY CONTAINED"
  },
  {
    suiteName: "Cross-Platform Account Balance UI Render Engine",
    type: "Selenium Grid Interactive Functional Regression",
    executionDate: "MAY 2026",
    totalAssertions: 185,
    passed: 183,
    failed: 2,
    logVerdict: "CODE ANOMALY DETECTED - AUTOMATED SELF-RECOVERY COMPLETED"
  }
];
---

<div class="space-y-4 font-mono mt-8">
  <div class="border-b border-white/10 pb-2">
    <h3 class="text-xs text-[var(--color-accent)] font-bold tracking-widest uppercase">
      📊 ARCHIVED TEST AUTOMATION FRAMEWORK AUDITS (ALLURE ENGINE RUNS)
    </h3>
  </div>

  <div class="grid grid-cols-1 gap-4">
    {historicalTestSuites.map((suite) => (
      <div class="bg-black/40 border border-white/5 rounded p-4 hover:border-[var(--color-accent)] transition-all duration-300">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-white/5 pb-2 mb-3 gap-1">
          <div>
            <h4 class="text-xs font-bold text-white tracking-wide uppercase">{suite.suiteName}</h4>
            <span class="text-[10px] text-white/40">{suite.type}</span>
          </div>
          <div class="text-[10px] text-[var(--color-subtext)] font-semibold whitespace-nowrap">
            TIMESTAMP: {suite.executionDate}
          </div>
        </div>

        <!-- Metric Block Grid Layer -->
        <div class="grid grid-cols-3 gap-2 text-center text-xs mb-3">
          <div class="bg-black/60 p-2 border border-white/5 rounded">
            <div class="text-[10px] text-white/40 uppercase">Asserts</div>
            <div class="text-sm font-bold text-white">{suite.totalAssertions}</div>
          </div>
          <div class="bg-black/60 p-2 border border-white/5 rounded">
            <div class="text-[10px] text-white/40 uppercase">Passed</div>
            <div class="text-sm font-bold text-[var(--color-accent)]">{suite.passed}</div>
          </div>
          <div class="bg-black/60 p-2 border border-white/5 rounded">
            <div class="text-[10px] text-white/40 uppercase">Failed</div>
            <div class="text-sm font-bold {suite.failed > 0 ? 'text-red-500 animate-pulse' : 'text-white/40'}">
              {suite.failed}
            </div>
          </div>
        </div>

        <div class="flex justify-between items-center bg-black/80 p-2 rounded text-[10px] border border-white/5">
          <span class="text-white/40">MAGI CORE DIAGNOSTIC LOG VERDICT:</span>
          <span class="font-bold tracking-wide {suite.failed > 0 ? 'text-[var(--color-highlight)]' : 'text-[var(--color-accent)]'}">
            [{suite.logVerdict}]
          </span>
        </div>
      </div>
    ))}
  </div>
</div>