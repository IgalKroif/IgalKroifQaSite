---
const skillCategories = [
  {
    title: "Core Automation & Java Stack",
    items: [
      { label: "Core Languages", value: "Java (Advanced), Python, JavaScript, SQL, HTML, CSS" },
      { label: "API Frameworks", value: "RestAssured (End-to-End Framework Architecture), Postman, SoapUI" },
      { label: "Testing Engines", value: "JUnit, TestNG, Selenium WebDriver, Pytest" }
    ]
  },
  {
    title: "Specialized Engineering & Workflows",
    items: [
      { label: "Custom Tooling", value: "Browser Extension Development, Workflow Automation Software" },
      { label: "AI Integration", value: "Kiro Usage with AI, Automated Test Design Optimization" },
      { label: "QA Methodology", value: "Advanced Manual Engineering, Exploratory Testing, Structural Test Design" },
      { label: "Databases & CI/CD", value: "PostgreSQL, Teradata SQL, Jenkins, GitHub Actions" }
    ]
  }
];
---
<section class="my-8">
  <h2>Technical Stack & Skillsets</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
    {skillCategories.map((category) => (
      <div class="p-4 rounded bg-eva-card border border-eva1-purple/30">
        <h3 class="text-md font-bold text-eva1-green mb-2">{category.title}</h3>
        <ul class="list-none space-y-1 text-sm">
          {category.items.map((skill) => (
            <li>🔹 <b>{skill.label}:</b> {skill.value}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>