<header class="text-center my-12">
  <h1 class="text-4xl md:text-5xl font-extrabold uppercase mb-2">Igal Kroif</h1> <!-- -->
  <p class="text-eva1-purple-glow font-mono tracking-widest uppercase text-sm mb-3">
    QA Engineer | Automation Specialist <!-- -->
  </p>

  <!-- 🚨 NERV EXCLUSIVE SUB-TEXT MAINSTRATE PROTOCOL -->
  <div class="nerv-slogan-container text-xs md:text-sm tracking-widest uppercase mb-6 font-serif italic hidden">
    "God's in his heaven. All's right in the world."
  </div>

  <!-- 📟 THE TERMINAL CORE -->
  <div class="max-w-xl mx-auto p-6 rounded bg-eva-card border border-eva1-purple/50 shadow-lg relative overflow-hidden font-mono text-left min-h-[160px]">
    <div class="absolute top-2 right-3 flex space-x-1">
      <span class="w-2 h-2 rounded-full bg-eva-orange animate-ping"></span>
      <span class="w-2 h-2 rounded-full bg-eva1-purple"></span>
    </div>
    
    <div id="terminal-screen" class="space-y-2 text-eva1-green">
      <!-- Lines injected dynamically by system initialization script -->
    </div>
  </div>
</header>

<script>
  // Keep your existing typewriter logic here completely untouched!
  const logSequence = [
    "Initializing terminal...",
    "Loading stack core sync...",
    "Java | Python | JavaScript | Selenium | SQL | Postman | Jenkins",
    "RestAssured API Framework Engine... ONLINE",
    "JUnit & TestNG Modules... SYNCHRONIZED",
    "AI-Kiro Core Unit... STABLE",
    "Ready."
  ];

  const screen = document.getElementById("terminal-screen");
  let lineIndex = 0;

  function typeLogLine() {
    if (!screen || lineIndex >= logSequence.length) return;
    const lineContainer = document.createElement("div");
    lineContainer.className = "flex items-start";
    const prefix = document.createElement("span");
    prefix.className = "text-eva-orange mr-2 select-none";
    prefix.innerHTML = lineIndex === logSequence.length - 1 ? "●" : "›";
    lineContainer.appendChild(prefix);
    const textNode = document.createElement("span");
    if (lineIndex === logSequence.length - 1) {
      textNode.className = "text-eva-orange font-bold animate-pulse";
    } else if (lineIndex === 2) {
      textNode.className = "text-eva-white";
    }
    lineContainer.appendChild(textNode);
    screen.appendChild(lineContainer);
    let charIndex = 0;
    const currentText = logSequence[lineIndex];
    function typeChar() {
      if (charIndex < currentText.length) {
        textNode.textContent += currentText.charAt(charIndex);
        charIndex++;
        setTimeout(typeChar, 15);
      } else {
        lineIndex++;
        setTimeout(typeLogLine, 350);
      }
    }
    typeChar();
  }
  document.addEventListener("DOMContentLoaded", typeLogLine);
</script>