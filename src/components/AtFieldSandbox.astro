---
/* 🛡️ ABSOLUTE TERROR SECURE EXPLOIT CONTAINMENT SHIELD SANDBOX */
---
<div class="bg-black/30 border border-white/10 rounded p-4 font-mono mt-6 relative overflow-hidden">
  
  <!-- Geometric Hexagonal Security Screen Overlay Layer -->
  <div id="at-field-barrier" class="absolute inset-0 bg-orange-600/10 backdrop-blur-[1px] z-20 flex flex-col items-center justify-center pointer-events-none opacity-0 transition-opacity duration-300">
    <!-- SVG Hexagon Stack Lattice Array Matrix -->
    <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#f39c12_1px,transparent_1px)] [background-size:16px_16px] animate-pulse"></div>
    <div class="border-2 border-orange-500 bg-black/90 text-orange-500 font-bold px-4 py-2 text-xs rounded tracking-widest text-center shadow-[0_0_20px_rgba(243,156,18,0.4)] uppercase">
      🚨 [ALERT]: INVALID TEXT SCHEMA BLOCKED BY A.T. FIELD SHIELD 🚨
      <div class="text-[10px] text-white/50 font-normal mt-1">MALICIOUS PAYLOAD OR OVERFLOW BOUND INTRUSION PREVENTED</div>
    </div>
  </div>

  <div class="text-xs text-white/40 uppercase tracking-widest mb-3 border-b border-white/10 pb-1 flex justify-between">
    <span>🛡️ EXPLOIT EXCLUSION & SHELL VALIDATION GROUND</span>
    <span class="text-orange-500">[AT-SHIELD SECURITY ON]</span>
  </div>

  <div class="space-y-3">
    <label class="block text-xs text-white/70">Execute Input Command Validation Run:</label>
    <div class="flex gap-2">
      <input 
        type="text" 
        id="at-security-input" 
        placeholder="Type inputs... (or test security boundaries with: <script> or DROP TABLE)" 
        class="flex-1 bg-black/60 border border-white/10 rounded px-2 py-1.5 text-xs text-white font-mono focus:outline-none focus:border-orange-500 transition-colors"
      />
      <button id="at-clear-btn" class="px-3 py-1.5 border border-white/20 text-white/60 text-xs rounded hover:text-white hover:border-white transition-colors">
        [ RESET ]
      </button>
    </div>
    <div class="text-[10px] text-white/30 tracking-tight leading-relaxed">
      CORE SPEC LOG: Dynamic validation scanning processes execution streams for multi-tier attack strings.
    </div>
  </div>
</div>

<script>
  const securityInput = document.getElementById('at-security-input') as HTMLInputElement | null;
  const atBarrier = document.getElementById('at-field-barrier');
  const clearBtn = document.getElementById('at-clear-btn');

  if (securityInput && atBarrier && clearBtn) {
    const maliciousPatterns = [
      '<script>', 'script', 'drop table', 'select *', 'or 1=1', 'delete from', 'alert('
    ];

    securityInput.addEventListener('input', () => {
      const rawText = securityInput.value.toLowerCase();
      
      // Determine if text strings match structural injection risk vectors
      const isThreat = maliciousPatterns.some(pattern => rawText.includes(pattern)) || rawText.length > 80;

      if (isThreat) {
        atBarrier.classList.remove('pointer-events-none', 'opacity-0');
        atBarrier.classList.add('opacity-100');
        securityInput.blur(); // Disengage focus immediately
        
        if (window.hasOwnProperty('playSystemSound')) {
          (window as any).playSystemSound('success'); // Fire notice tone
        }
      }
    });

    clearBtn.addEventListener('click', () => {
      securityInput.value = "";
      atBarrier.classList.remove('opacity-100');
      atBarrier.classList.add('pointer-events-none', 'opacity-0');
    });
  }
</script>