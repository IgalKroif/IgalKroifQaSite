---
const experiences = [
  {
    role: "QA Engineer / Automation Specialist",
    company: "Tesnet Group Ltd",
    type: "Full-time",
    duration: "MAY 2023 – PRESENT",
    location: "TEL AVIV (HYBRID)",
    points: [
      "Architected and scaled robust, end-to-end API test automation frameworks from scratch using Java and RestAssured.",
      "Configured comprehensive automation suites driven by JUnit and TestNG to safeguard core banking backend stability.",
      "Engineered custom browser extensions and tailored workflow optimization software, significantly increasing cross-team operational speeds.",
      "Pioneered cutting-edge testing methodologies by implementing Kiro usage integrated with AI engines to streamline test generation."
    ]
  },
  {
    role: "Manual Engineering Specialist",
    company: "Qualitest",
    type: "Full-time",
    duration: "FEB 2022 – MAY 2023",
    location: "TEL AVIV DISTRICT",
    points: [
      "Served as a core Manual Engineering Specialist, authoring high-coverage functional, integration, and regression test specifications.",
      "Leveraged deep exploratory testing principles alongside Teradata SQL data mapping models to validate sophisticated system integrations.",
      "Deconstructed complex software requirements into concrete structural designs, uncovering critical software defects."
    ]
  }
];
---

<div class="font-mono w-full max-w-2xl mx-auto relative group mt-4" id="experience-carousel">
  
  <button id="prev-exp" class="absolute -left-16 top-[60%] -translate-y-1/2 z-30 bg-black/90 border border-[var(--color-highlight)] text-[var(--color-highlight)] w-12 h-20 flex items-center justify-center rounded text-2xl transition-all duration-300 cursor-pointer shadow-[0_0_15px_rgba(var(--color-highlight-rgb),0.3)] hover:bg-[var(--color-highlight)] hover:text-black">
    &larr;
  </button>
  <button id="next-exp" class="absolute -right-16 top-[60%] -translate-y-1/2 z-30 bg-black/90 border border-[var(--color-highlight)] text-[var(--color-highlight)] w-12 h-20 flex items-center justify-center rounded text-2xl transition-all duration-300 cursor-pointer shadow-[0_0_15px_rgba(var(--color-highlight-rgb),0.3)] hover:bg-[var(--color-highlight)] hover:text-black">
    &rarr;
  </button>

  <div class="border-b border-[var(--color-highlight)]/20 pb-4 mb-4 flex flex-col justify-start items-start gap-2 w-full">
    <span class="text-xs tracking-widest text-[var(--color-highlight)] break-words w-full">[ NERV TACTICAL OPERATION LOGS ]</span>
    <span class="text-[8px] opacity-60 bg-black/40 px-1.5 py-0.5 border border-white/10 rounded self-start">ACCESS LEVEL: SYSTEM ADMINISTRATOR REQUIRED</span>
  </div>

  <div class="relative overflow-hidden min-h-[380px] px-2">
    {experiences.map((exp, index) => (
      <div 
        class="exp-slide absolute top-0 left-0 w-full transition-all duration-500 ease-in-out" 
        data-index={index}
      >
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4 gap-2">
          <div class="min-w-0">
            <h3 class="text-xs md:text-sm font-bold tracking-wide text-[var(--color-highlight)]">
              OPERATION: {exp.role.toUpperCase()}
            </h3>
            <p class="text-xs md:text-sm text-white/70 mt-1">
              {exp.company} &bull; {exp.type}
            </p>
          </div>
          <div class="text-right text-xs md:text-sm leading-tight text-[var(--color-highlight)] border border-[var(--color-highlight)]/30 bg-black/60 px-3 py-2 rounded shrink-0 whitespace-nowrap">
            <div>{exp.duration}</div>
            <div>{exp.location}</div>
          </div>
        </div>

        <ul class="space-y-3 text-xs md:text-sm text-white/60 pl-4 border-l border-[var(--color-highlight)]/40 list-disc">
          {exp.points.map(point => (
            <li class="leading-relaxed">{point}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.exp-slide');
    const prevBtn = document.getElementById('prev-exp') as HTMLElement | null;
    const nextBtn = document.getElementById('next-exp') as HTMLElement | null;
    
    let currentIndex = 0;

    function updateSlides() {
      slides.forEach((slide) => {
        const slideIndex = parseInt((slide as HTMLElement).dataset.index || '0');
        if (slideIndex === currentIndex) {
          (slide as HTMLElement).style.opacity = '1';
          (slide as HTMLElement).style.transform = 'translateX(0)';
          (slide as HTMLElement).style.position = 'relative';
          (slide as HTMLElement).style.zIndex = '10';
        } else {
          (slide as HTMLElement).style.opacity = '0';
          (slide as HTMLElement).style.transform = slideIndex < currentIndex ? 'translateX(-20px)' : 'translateX(20px)';
          (slide as HTMLElement).style.position = 'absolute';
          (slide as HTMLElement).style.zIndex = '0';
        }
      });

      if (prevBtn) {
        if (currentIndex === 0) {
          prevBtn.style.opacity = '0';
          prevBtn.style.pointerEvents = 'none';
          prevBtn.style.cursor = 'default';
        } else {
          prevBtn.style.opacity = '1';
          prevBtn.style.pointerEvents = 'auto';
          prevBtn.style.cursor = 'pointer';
        }
      }

      if (nextBtn) {
        if (currentIndex === slides.length - 1) {
          nextBtn.style.opacity = '0';
          nextBtn.style.pointerEvents = 'none';
          nextBtn.style.cursor = 'default';
        } else {
          nextBtn.style.opacity = '1';
          nextBtn.style.pointerEvents = 'auto';
          nextBtn.style.cursor = 'pointer';
        }
      }
    }

    if (slides.length > 0) {
      updateSlides();
    }

    prevBtn?.addEventListener('click', () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateSlides();
      }
    });

    nextBtn?.addEventListener('click', () => {
      if (currentIndex < slides.length - 1) {
        currentIndex++;
        updateSlides();
      }
    });
  });
</script>
