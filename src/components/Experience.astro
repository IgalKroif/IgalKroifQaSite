---
const timeline = [
  {
    year: "2022",
    role: "QA Engineer – Bank A",
    description:
      "Implemented Selenium test suite for core banking platform, reducing regression testing time by 40%."
  },
  {
    year: "2023",
    role: "Senior QA Engineer – Bank B",
    description:
      "Led automation effort for API testing with Postman and integrated CI/CD pipelines using Jenkins."
  },
  {
    year: "2024",
    role: "Lead QA Engineer – Bank C",
    description:
      "Designed end‑to‑end testing framework in Java & Python, introduced performance testing, and mentored junior QA staff."
  }
];
---
<section id="experience" class="py-20 px-4 max-w-4xl mx-auto">
  <h2 class="text-3xl font-bold mb-6 border-b border-neon pb-2">Experience</h2>
  <ul class="space-y-6">
    {timeline.map((item) => (
      <li class="border-l-2 border-neon pl-4">
        <span class="text-neon font-mono">{item.year}</span>
        <h3 class="text-xl font-semibold">{item.role}</h3>
        <p>{item.description}</p>
      </li>
    ))}
  </ul>
</section>