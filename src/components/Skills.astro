---
const skills = {
  Languages: ["Java", "Python", "JavaScript", "SQL"],
  "Testing Frameworks": ["Selenium WebDriver", "Jest", "Mocha", "Postman"],
  "CI/CD Tools": ["Jenkins", "GitHub Actions", "Docker"],
  "Other": ["Git", "GitHub", "REST APIs"]
};
---
<section id="skills" class="py-20 px-4 max-w-4xl mx-auto">
  <h2 class="text-3xl font-bold mb-6 border-b border-neon pb-2">Skills</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {Object.entries(skills).map(([category, items]) => (
      <div class="border border-neon rounded p-4">
        <h3 class="text-xl font-semibold mb-2">{category}</h3>
        <ul class="list-disc list-inside">
          {items.map(item => <li>{item}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>