---
const timeline = [
  {
    role: "QA Engineer",
    company: "Tesnet Group Ltd",
    type: "Full-time",
    location: "Tel Aviv District, Israel (Hybrid)",
    period: "May 2023 – Present",
    current: true,
    bullets: [
      "Driving test automation implementation across core operational environments.",
      "Utilizing Python for core logic automation testing frameworks, test scripting, and script execution.",
      "Leading regression cycles, structural test designs, and technical training initiatives for engineering staff."
    ]
  },
  {
    role: "QA Engineer",
    company: "Qualitest",
    type: "Full-time",
    location: "Tel Aviv District, Israel",
    period: "Feb 2022 – May 2023",
    current: false,
    bullets: [
      "Executed database and application validation layers utilizing Teradata SQL data mapping models.",
      "Authored functional, regression, and integration test specifications for complex backend platforms.",
      "Identified software defects, validated fixes, and ensured high product quality under aggressive delivery cycles."
    ]
  }
];
---
<section class="my-8">
  <h2>Experience</h2>
  <div class="mt-6 space-y-8">
    {timeline.map((item) => (
      <div class={`border-l-2 pl-4 ${item.current ? 'border-eva1-purple' : 'border-eva-muted'}`}>
        <div class="flex justify-between items-baseline flex-wrap">
          <h3 class="text-xl font-bold text-eva-white">{item.role}</h3>
          <span class={`text-sm ${item.current ? 'text-eva-orange' : 'text-eva-muted'}`}>{item.period}</span>
        </div>
        <p class={`${item.current ? 'text-eva1-purple-glow' : 'text-eva-muted'} font-medium`}>
          {item.company} • {item.type}
        </p>
        <p class="text-sm text-eva-muted mb-2">{item.location}</p>
        <ul class="list-disc list-inside space-y-1 text-sm">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>