---
const timeline = [
  {
    role: "QA Engineer",
    company: "Tesnet Group Ltd",
    type: "Full-time",
    location: "Tel Aviv District, Israel (Hybrid)",
    period: "May 2023 – Present",
    current: true,
    bullets: [
      "Architected and scaled robust, end-to-end API test automation frameworks from scratch using Java and RestAssured.",
      "Configured comprehensive automation suites driven by JUnit and TestNG to safeguard core banking backend stability.",
      "Engineered custom browser extensions and tailored workflow optimization software, significantly increasing cross-team operational speeds and testing efficiency for QA engineers.",
      "Pioneered cutting-edge testing methodologies by implementing Kiro usage integrated with AI engines to streamline test generation and script maintenance."
    ]
  },
  {
    role: "QA Engineer (Manual & Database Validation)",
    company: "Qualitest",
    type: "Full-time",
    location: "Tel Aviv District, Israel",
    period: "Feb 2022 – May 2023",
    current: false,
    bullets: [
      "Served as a core Manual Engineering Specialist, authoring high-coverage functional, integration, and regression test specifications for enterprise banking layers.",
      "Leveraged deep exploratory testing principles alongside Teradata SQL data mapping models to validate sophisticated system integrations and database states.",
      "Deconstructed complex software requirements into concrete structural designs, uncovering critical software defects ahead of aggressive deployment dates."
    ]
  }
];
---
<section class="my-8">
  <h2>Experience</h2>
  <div class="mt-6 space-y-8">
    {timeline.map((item) => (
      <div class={`border-l-2 pl-4 ${item.current ? 'border-eva1-purple' : 'border-eva-muted'}`}>
        <div class="flex justify-between items-baseline flex-wrap">
          <h3 class="text-xl font-bold text-eva-white">{item.role}</h3>
          <span class={`text-sm ${item.current ? 'text-eva-orange' : 'text-eva-muted'}`}>{item.period}</span>
        </div>
        <p class={`${item.current ? 'text-eva1-purple-glow' : 'text-eva-muted'} font-medium`}>
          {item.company} • {item.type}
        </p>
        <p class="text-sm text-eva-muted mb-2">{item.location}</p>
        <ul class="list-disc list-inside space-y-1 text-sm">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>